{% extends "base.html.twig" %}

{% block title %}E-Commerce - Accueil{% endblock %}

{% block content %}
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* Hero Section */
    .hero {
        position: relative;
        height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        top: -100px;
        right: -100px;
        animation: float 6s ease-in-out infinite;
    }

    .hero::after {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        bottom: -50px;
        left: -50px;
        animation: float 8s ease-in-out infinite reverse;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(30px); }
    }

    .hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        color: white;
        max-width: 600px;
        padding: 20px;
    }

    .hero h1 {
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 20px;
        animation: slideDown 0.8s ease-out;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .hero p {
        font-size: 1.5rem;
        margin-bottom: 30px;
        animation: slideUp 0.8s ease-out 0.2s both;
        opacity: 0.95;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero-buttons {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeIn 0.8s ease-out 0.4s both;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .hero-buttons .btn {
        padding: 15px 40px;
        font-size: 1.1rem;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary-hero {
        background: white;
        color: #667eea;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .btn-primary-hero:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    }

    .btn-secondary-hero {
        background: transparent;
        color: white;
        border: 2px solid white;
    }

    .btn-secondary-hero:hover {
        background: white;
        color: #667eea;
        transform: translateY(-3px);
    }

    /* Features Section */
    .features {
        padding: 80px 20px;
        background: #f8f9fa;
    }

    .features-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-title {
        text-align: center;
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 60px;
        color: #2d3748;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }

    .feature-card {
        background: white;
        padding: 40px 30px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(102, 126, 234, 0.2);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.8rem;
    }

    .feature-card h3 {
        font-size: 1.3rem;
        margin-bottom: 15px;
        color: #2d3748;
    }

    .feature-card p {
        color: #718096;
        line-height: 1.6;
    }

    /* Products Section */
    .products-section {
        padding: 80px 20px;
        background: white;
    }

    .products-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin-top: 40px;
    }

    .product-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(102, 126, 234, 0.2);
    }

    .product-image {
        width: 100%;
        height: 250px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-image::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0);
        transition: background 0.3s ease;
    }

    .product-card:hover .product-image::before {
        background: rgba(0, 0, 0, 0.1);
    }

    .product-info {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .product-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 10px;
    }

    .product-price {
        font-size: 1.5rem;
        font-weight: 800;
        color: #667eea;
        margin-bottom: 15px;
    }

    .product-description {
        color: #718096;
        font-size: 0.95rem;
        margin-bottom: 15px;
        flex: 1;
        line-height: 1.5;
    }

    .product-category {
        display: inline-block;
        background: #f0f4ff;
        color: #667eea;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .product-card .btn {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        text-align: center;
        display: block;
    }

    .product-card .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
    }

    /* CTA Section */
    .cta-section {
        padding: 80px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-align: center;
    }

    .cta-content {
        max-width: 600px;
        margin: 0 auto;
    }

    .cta-section h2 {
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 800;
    }

    .cta-section p {
        font-size: 1.2rem;
        margin-bottom: 30px;
        opacity: 0.95;
    }

    .cta-section .btn-primary-hero {
        background: white;
        color: #667eea;
    }

    /* No products message */
    .no-products {
        text-align: center;
        padding: 60px 20px;
        color: #718096;
    }

    .no-products svg {
        width: 80px;
        height: 80px;
        margin: 20px auto;
        opacity: 0.5;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero h1 {
            font-size: 2.5rem;
        }

        .hero p {
            font-size: 1.2rem;
        }

        .hero-buttons {
            flex-direction: column;
            align-items: center;
        }

        .hero-buttons .btn {
            width: 100%;
        }

        .section-title {
            font-size: 2rem;
        }

        .cta-section h2 {
            font-size: 1.8rem;
        }
    }

    /* Banner Section */
    .banner-section {
        position: relative;
        height: 400px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .banner-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-size: cover;
        background-position: center;
        z-index: 1;
        opacity: 0.5;
    }

    .banner-content {
        position: relative;
        z-index: 10;
        text-align: center;
        color: white;
        max-width: 600px;
        padding: 40px;
    }

    .banner-section h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 15px;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    .banner-section p {
        font-size: 1.2rem;
        margin-bottom: 25px;
        opacity: 0.95;
        line-height: 1.6;
        text-shadow: 0 1px 5px rgba(0, 0, 0, 0.2);
    }

    .banner-section .btn {
        display: inline-block;
        padding: 12px 35px;
        background: white;
        color: #667eea;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .banner-section .btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 768px) {
        .banner-section {
            height: 300px;
        }

        .banner-section h2 {
            font-size: 1.8rem;
        }

        .banner-section p {
            font-size: 1rem;
        }

        .banner-content {
            padding: 20px;
        }
    }

</style>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-content">
        <h1>Bienvenue dans notre boutique</h1>
        <p>Découvrez nos produits de qualité à prix imbattables</p>
        <div class="hero-buttons">
            <a href="#products" class="btn btn-primary-hero">Découvrir les produits</a>
            {% if not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_home') }}" class="btn btn-secondary-hero">Commencer les achats</a>
            {% endif %}
        </div>
    </div>
</section>

<!-- Banner Section -->
{% if banner %}
<section class="banner-section" style="background-image: url('{{ asset(banner.imagePath) }}');">
    <div class="banner-section::before" style="background-image: url('{{ asset(banner.imagePath) }}');"></div>
    <div class="banner-content">
        {% if banner.title %}
            <h2>{{ banner.title }}</h2>
        {% endif %}
        {% if banner.description %}
            <p>{{ banner.description }}</p>
        {% endif %}
        {% if banner.buttonText and banner.buttonUrl %}
            <a href="{{ banner.buttonUrl }}" class="btn">{{ banner.buttonText }}</a>
        {% endif %}
    </div>
</section>
{% endif %}

<!-- Features Section -->
<section class="features">
    <div class="features-container">
        <h2 class="section-title">Pourquoi nous choisir ?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🚚</div>
                <h3>Livraison rapide</h3>
                <p>Nous livrons vos commandes en 2-3 jours ouvrables partout en France.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💳</div>
                <h3>Paiement sécurisé</h3>
                <p>Tous vos paiements sont protégés par les normes de sécurité les plus strictes.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔄</div>
                <h3>Retours gratuits</h3>
                <p>Vous avez 30 jours pour retourner vos produits sans frais supplémentaires.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💬</div>
                <h3>Support 24/7</h3>
                <p>Notre équipe est disponible pour répondre à toutes vos questions.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⭐</div>
                <h3>Meilleure qualité</h3>
                <p>Nous sélectionnons uniquement les meilleurs produits pour vous.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎁</div>
                <h3>Promotions régulières</h3>
                <p>Bénéficiez de réductions exclusives et d'offres spéciales toute l'année.</p>
            </div>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="products-section" id="products">
    <div class="products-container">
        <h2 class="section-title">Nos produits</h2>
        
        {% if products is empty %}
            <div class="no-products">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6 4a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1zM9.5 3a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>
                    <path d="M2.5 2c0-.55.45-1 1-1h9c.55 0 1 .45 1 1v1h2c.55 0 1 .45 1 1v6c0 .55-.45 1-1 1h-1v4c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1v-4H2c-.55 0-1-.45-1-1V4c0-.55.45-1 1-1h.5V2zm1 3v5h9V5h-9zm0-2v1h9V2h-9z"/>
                </svg>
                <h3>Aucun produit disponible</h3>
                <p>Revenez bientôt pour découvrir notre catalogue !</p>
            </div>
        {% else %}
            <div class="products-grid">
                {% for product in products %}
                    <div class="product-card">
                        <div class="product-image">
                            {% if product.image %}
                                {% set imageSrc = product.image starts with 'http' ? product.image : asset(product.image) %}
                                <img src="{{ imageSrc }}" alt="{{ product.name }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                            {% else %}
                                <span style="color: rgba(255,255,255,0.5); font-size: 3rem;">📦</span>
                            {% endif %}
                        </div>
                        <div class="product-info">
                            {% if product.category %}
                                <span class="product-category">{{ product.category }}</span>
                            {% endif %}
                            <h3 class="product-name">{{ product.name }}</h3>
                            <p class="product-price">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            <p class="product-description">{{ product.description|slice(0, 100) }}{% if product.description|length > 100 %}...{% endif %}</p>
                            
                            {% if is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn">Voir le produit</a>
                            {% elseif not is_granted('ROLE_USER') %}
                                <a href="{{ path('app_login') }}" class="btn">Se connecter pour acheter</a>
                            {% else %}
                                <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;">Admin - Non disponible</button>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="cta-content">
        <h2>Prêt à commencer ?</h2>
        <p>Rejoignez des milliers de clients satisfaits et commencez vos achats dès maintenant.</p>
        {% if not is_granted('ROLE_USER') %}
            <a href="{{ path('app_register') }}" class="btn btn-primary-hero">Créer un compte</a>
        {% else %}
            <a href="{{ path('app_home') }}" class="btn btn-primary-hero">Continuer les achats</a>
        {% endif %}
    </div>
</section>

{% endblock %}
