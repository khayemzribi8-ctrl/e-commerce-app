{% extends "base.html.twig" %}

{% block title %}Nos Produits - E-Commerce{% endblock %}

{% block extra_css %}
<style>
    .hero-section {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        color: white;
        padding: 3rem 0;
        border-radius: 1rem;
        margin-bottom: 2rem;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
    }

    .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .hero-section p {
        font-size: 1.1rem;
        opacity: 0.95;
    }

    .product-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .product-image {
        height: 250px;
        object-fit: cover;
        overflow: hidden;
    }

    .product-image-placeholder {
        height: 250px;
        background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-body {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .product-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    .product-category {
        font-size: 0.85rem;
        color: #6c757d;
        margin-bottom: 0.75rem;
        font-weight: 600;
    }

    .product-description {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 1rem;
        flex-grow: 1;
        line-height: 1.5;
    }

    .product-price {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0d6efd;
        margin: 0.75rem 0;
    }

    .product-footer {
        margin-top: auto;
        display: flex;
        gap: 0.5rem;
    }

    .product-footer .btn {
        flex: 1;
    }

    .no-products {
        text-align: center;
        padding: 4rem 0;
    }

    .no-products i {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
        .hero-section h1 {
            font-size: 2rem;
        }

        .product-image {
            height: 200px;
        }

        .product-image-placeholder {
            height: 200px;
        }
    }
</style>
{% endblock %}

{% block content %}
<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1><i class="bi bi-bag-check"></i> Notre Catalogue</h1>
        <p>Découvrez notre sélection de produits de qualité</p>
    </div>
</div>

<!-- Products Section -->
{% if products is empty %}
    <div class="no-products">
        <i class="bi bi-inbox"></i>
        <h4>Aucun produit disponible</h4>
        <p class="text-muted">Revenez bientôt pour découvrir nos produits !</p>
    </div>
{% else %}
    <div class="row g-4">
        {% for product in products %}
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="card product-card h-100">
                    <!-- Product Image -->
                    {% if product.image %}
                        {% set imageSrc = product.image starts with 'http' ? product.image : asset(product.image) %}
                        <img src="{{ imageSrc }}" class="card-img-top product-image" alt="{{ product.name }}" loading="lazy">
                    {% else %}
                        <div class="product-image-placeholder">
                            <div class="text-center">
                                <i class="bi bi-image" style="font-size: 3rem; color: #dee2e6;"></i>
                                <p class="text-muted mb-0 mt-2">Pas d'image</p>
                            </div>
                        </div>
                    {% endif %}

                    <!-- Product Body -->
                    <div class="card-body product-body">
                        <h5 class="product-title" title="{{ product.name }}">{{ product.name }}</h5>
                        
                        {% if product.category %}
                            <p class="product-category">
                                <i class="bi bi-tag"></i> {{ product.category }}
                            </p>
                        {% endif %}

                        <p class="product-description">{{ product.description|slice(0, 90)|striptags }}{% if product.description|length > 90 %}...{% endif %}</p>

                        <div class="product-price">{{ "%.2f"|format(product.price) }} €</div>

                        <!-- Stock Status -->
                        <div>
                            {% if product.stock > 10 %}
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> En stock ({{ product.stock }})
                                </span>
                            {% elseif product.stock > 0 %}
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-exclamation-triangle"></i> Stock faible ({{ product.stock }})
                                </span>
                            {% else %}
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle"></i> Rupture
                                </span>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Product Footer -->
                    <div class="card-footer bg-white border-top-0">
                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-eye"></i> Voir détails
                        </a>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    
    {% if totalPages is defined and totalPages > 1 %}
        <nav aria-label="Pagination produits" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage <= 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_home_shop', {'page': currentPage - 1}) }}" tabindex="-1">Précédent</a>
                </li>

                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_home_shop', {'page': p}) }}">{{ p }}</a>
                    </li>
                {% endfor %}

                <li class="page-item {{ currentPage >= totalPages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_home_shop', {'page': currentPage + 1}) }}">Suivant</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endif %}
{% endblock %}
