{% extends "base.html.twig" %}

{% block title %}Connexion - E-Commerce{% endblock %}

{% block extra_css %}
<style>
    .auth-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        border-radius: 1rem;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .auth-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        color: white;
        padding: 2rem 1.5rem;
        border-radius: 1rem 1rem 0 0;
        text-align: center;
    }

    .auth-header h2 {
        margin-bottom: 0;
        font-weight: 700;
    }

    .auth-body {
        padding: 2rem 1.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.5rem;
    }

    .divider {
        text-align: center;
        margin: 1.5rem 0;
        position: relative;
    }

    .divider::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background-color: #dee2e6;
    }

    .divider span {
        background-color: white;
        padding: 0 0.5rem;
        position: relative;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .auth-link {
        text-align: center;
        padding-top: 1rem;
        border-top: 1px solid #e9ecef;
        margin-top: 1.5rem;
    }

    .auth-link p {
        margin-bottom: 0;
        color: #6c757d;
    }

    .auth-link a {
        font-weight: 600;
        color: #0d6efd;
        text-decoration: none;
    }

    .auth-link a:hover {
        text-decoration: underline;
    }

    .alert {
        margin-bottom: 1rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="card auth-card">
        <div class="auth-header">
            <i class="bi bi-box-arrow-in-right" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></i>
            <h2>Connexion</h2>
        </div>

        <div class="auth-body">
            {% if error %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle"></i> 
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <form method="post" novalidate>
                <div class="form-group">
                    <label for="email" class="form-label">
                        <i class="bi bi-envelope"></i> Adresse Email
                    </label>
                    <input type="email" id="email" name="_username" class="form-control form-control-lg" 
                           value="{{ last_username }}" required autofocus placeholder="votreemail@exemple.com">
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">
                        <i class="bi bi-lock"></i> Mot de passe
                    </label>
                    <input type="password" id="password" name="_password" class="form-control form-control-lg" 
                           required placeholder="••••••••">
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-box-arrow-in-right"></i> Se connecter
                </button>
            </form>

            <div class="auth-link">
                <p>
                    <a href="{{ path('app_forgot_password') }}">Mot de passe oublié ?</a>
                </p>
                <p class="mt-2">Pas encore de compte? 
                    <a href="{{ path('app_register') }}">S'inscrire maintenant</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
