{% extends "base.html.twig" %}

{% block title %}Panier - E-Commerce{% endblock %}

{% block extra_css %}
<style>
    .cart-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        color: white;
        padding: 2rem 0;
        border-radius: 1rem;
        margin-bottom: 2rem;
    }

    .cart-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0;
    }

    .cart-table {
        background-color: white;
        border-radius: 0.75rem;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .cart-item-row {
        border-bottom: 1px solid #e9ecef;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .cart-item-row:last-child {
        border-bottom: none;
    }

    .cart-item-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 0.5rem;
    }

    .cart-item-details {
        flex-grow: 1;
    }

    .cart-item-name {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }

    .cart-item-name a {
        color: #0d6efd;
        text-decoration: none;
    }

    .cart-item-name a:hover {
        text-decoration: underline;
    }

    .cart-item-price {
        color: #6c757d;
        font-size: 0.95rem;
    }

    .cart-item-price-total {
        font-weight: 700;
        font-size: 1.2rem;
        color: #0d6efd;
        min-width: 100px;
        text-align: right;
    }

    .cart-summary {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .summary-card {
        background-color: white;
        padding: 2rem;
        border-radius: 0.75rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .summary-total {
        font-size: 2rem;
        font-weight: 700;
        color: #0d6efd;
        margin-bottom: 1rem;
    }

    .empty-cart {
        text-align: center;
        padding: 4rem 0;
    }

    .empty-cart i {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
        .cart-item-row {
            flex-direction: column;
            text-align: center;
        }

        .cart-item-image {
            width: 100px;
            height: 100px;
        }

        .cart-item-price-total {
            text-align: center;
        }

        .cart-summary {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block content %}
<!-- Cart Header -->
<div class="cart-header">
    <div class="container">
        <h1><i class="bi bi-cart3"></i> Mon Panier</h1>
    </div>
</div>

{% if cartItems is empty %}
    <!-- Empty Cart -->
    <div class="empty-cart">
        <i class="bi bi-cart-x"></i>
        <h4>Votre panier est vide</h4>
        <p class="text-muted mb-3">Commencez vos achats en découvrant nos produits</p>
        <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg">
            <i class="bi bi-bag-check"></i> Continuer vos achats
        </a>
    </div>
{% else %}
    <!-- Cart Items -->
    <div class="row">
        <div class="col-lg-8">
            <div class="cart-table">
                {% for item in cartItems %}
                    <div class="cart-item-row">
                        {% if item.product.image %}
                            {% set imageSrc = item.product.image starts with 'http' ? item.product.image : asset(item.product.image) %}
                            <img src="{{ imageSrc }}" alt="{{ item.product.name }}" class="cart-item-image" loading="lazy">
                        {% else %}
                            <div class="cart-item-image bg-light d-flex align-items-center justify-content-center">
                                <i class="bi bi-image text-muted"></i>
                            </div>
                        {% endif %}

                        <div class="cart-item-details">
                            <div class="cart-item-name">
                                <a href="{{ path('app_product_show', {'id': item.product.id}) }}">
                                    {{ item.product.name }}
                                </a>
                            </div>
                            <div class="cart-item-price">
                                <strong>Prix unitaire:</strong> {{ "%.2f"|format(item.product.price) }} €
                            </div>
                            <div class="cart-item-price">
                                <strong>Quantité:</strong> {{ item.quantity }}
                            </div>
                        </div>

                        <div class="cart-item-price-total">
                            {{ "%.2f"|format(item.product.price * item.quantity) }} €
                        </div>

                        <form method="POST" action="{{ path('app_cart_remove', {'id': item.id}) }}" class="ms-2">
                            <button type="submit" class="btn btn-danger btn-sm" title="Supprimer du panier">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                {% endfor %}
            </div>

            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> Continuer les achats
            </a>
        </div>

        <!-- Cart Summary -->
        <div class="col-lg-4">
            <div class="summary-card">
                <h5 class="mb-3">
                    <i class="bi bi-receipt"></i> Résumé de la commande
                </h5>

                <div class="mb-3 pb-3 border-bottom">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Nombre d'articles:</span>
                        <strong>{{ cartItems|length }}</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Sous-total:</span>
                        <strong>{{ "%.2f"|format(total) }} €</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Frais de port:</span>
                        <strong class="text-success">Gratuit</strong>
                    </div>
                </div>

                <div class="summary-total d-flex justify-content-between align-items-center">
                    <span>Total:</span>
                    <span>{{ "%.2f"|format(total) }} €</span>
                </div>

                <form method="POST" action="{{ path('app_order_checkout') }}">
                    <button type="submit" class="btn btn-success btn-lg w-100">
                        <i class="bi bi-check-circle"></i> Passer la commande
                    </button>
                </form>

                <div class="alert alert-info mt-3 mb-0" role="alert">
                    <i class="bi bi-info-circle"></i>
                    <small>Livraison rapide et gratuite sur toutes les commandes</small>
                </div>
            </div>
        </div>
    </div>
{% endif %}
{% endblock %}
