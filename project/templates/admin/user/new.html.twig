{% extends "base.html.twig" %}

{% block title %}Ajouter un utilisateur - Admin{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h1 class="h2">Ajouter un utilisateur</h1>
                <a href="{{ path('admin_user_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'class': 'form-user', 'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'votreemail@exemple.com'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.firstName, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.firstName, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(form.firstName) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.lastName, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.lastName, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            {{ form_errors(form.lastName) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.password.first) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.password.second) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.phone, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.phone, {'attr': {'class': 'form-control form-control-lg'}}) }}
                        {{ form_errors(form.phone) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.address, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                        {{ form_widget(form.address, {'attr': {'class': 'form-control form-control-lg'}}) }}
                        {{ form_errors(form.address) }}
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Rôles</label>
                        <div>
                            {% for child in form.roles %}
                                <div class="form-check form-check-inline">
                                    {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(child, null, {'label_attr': {'class': 'form-check-label ms-1'}}) }}
                                </div>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.roles) }}
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                            <i class="bi bi-check-circle"></i> Créer l'utilisateur
                        </button>
                        <a href="{{ path('admin_user_index') }}" class="btn btn-outline-secondary btn-lg">Annuler</a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
