{% extends "base.html.twig" %}

{% block title %}Commandes - Admin{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Commandes</h1>
        <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour produits
        </a>
    </div>

    {% if orders is empty %}
        <div class="alert alert-info">
            Aucune commande pour le moment.
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Date</th>
                        <th>Client</th>
                        <th>Email</th>
                        <th>Montant</th>
                        <th>Statut</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        <tr>
                            <td>{{ order.id }}</td>
                            <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ order.user.firstName ~ ' ' ~ order.user.lastName }}</td>
                            <td>{{ order.user.email }}</td>
                            <td>{{ order.totalAmount }} €</td>
                            <td>
                                {% if order.status == 'pending' %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% elseif order.status == 'completed' %}
                                    <span class="badge bg-success">Complétée</span>
                                {% elseif order.status == 'cancelled' %}
                                    <span class="badge bg-danger">Annulée</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ order.status }}</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_order_show', {id: order.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Détails
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
