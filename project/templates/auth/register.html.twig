{% extends "base.html.twig" %}

{% block title %}Inscription - E-Commerce{% endblock %}

{% block extra_css %}
<style>
    .auth-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        border-radius: 1rem;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .auth-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0b5ed7 100%);
        color: white;
        padding: 2rem 1.5rem;
        border-radius: 1rem 1rem 0 0;
        text-align: center;
    }

    .auth-header h2 {
        margin-bottom: 0;
        font-weight: 700;
    }

    .auth-body {
        padding: 2rem 1.5rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.5rem;
    }

    .divider {
        text-align: center;
        margin: 1.5rem 0;
        position: relative;
    }

    .divider::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 1px;
        background-color: #dee2e6;
    }

    .divider span {
        background-color: white;
        padding: 0 0.5rem;
        position: relative;
        color: #6c757d;
        font-size: 0.9rem;
    }

    .auth-link {
        text-align: center;
        padding-top: 1rem;
        border-top: 1px solid #e9ecef;
        margin-top: 1.5rem;
    }

    .auth-link p {
        margin-bottom: 0;
        color: #6c757d;
    }

    .auth-link a {
        font-weight: 600;
        color: #0d6efd;
        text-decoration: none;
    }

    .auth-link a:hover {
        text-decoration: underline;
    }

    .alert {
        margin-bottom: 1rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="auth-container">
    <div class="card auth-card">
        <div class="auth-header">
            <i class="bi bi-person-plus" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></i>
            <h2>Créer un compte</h2>
        </div>

        <div class="auth-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-group">
                {{ form_label(form.email, 'Adresse Email', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'votreemail@exemple.com'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.firstName, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.firstName, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Jean'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.lastName, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.lastName, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Dupont'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.password.first, {'attr': {'class': 'form-control form-control-lg', 'placeholder': '••••••••'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.password.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.password.second, {'attr': {'class': 'form-control form-control-lg', 'placeholder': '••••••••'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.phone, 'Téléphone (optionnel)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.phone, {'attr': {'class': 'form-control form-control-lg', 'placeholder': '+33 6 12 34 56 78'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.address, 'Adresse (optionnel)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.address, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Rue, numéro, ville'}}) }}
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-person-plus"></i> S'inscrire
            </button>

            {{ form_end(form) }}

            <div class="auth-link">
                <p>Vous avez déjà un compte? 
                    <a href="{{ path('app_login') }}">Se connecter</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
