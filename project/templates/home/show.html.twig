{% extends "base.html.twig" %}

{% block title %}{{ product.name }} - E-Commerce{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-6">
        {% if product.image %}
            {% set imageSrc = product.image starts with 'http' ? product.image : asset(product.image) %}
            <img src="{{ imageSrc }}" alt="{{ product.name }}" class="img-fluid" loading="lazy">
        {% else %}
            <div class="bg-secondary" style="height: 400px; display: flex; align-items: center; justify-content: center;">
                <span class="text-white">Pas d'image</span>
            </div>
        {% endif %}
    </div>
    <div class="col-md-6">
        <h1>{{ product.name }}</h1>
        
        {% if product.category %}
            <p><strong>Catégorie:</strong> {{ product.category }}</p>
        {% endif %}
        
        <hr>
        
        <h3 class="text-primary">{{ product.price }} €</h3>
        
        <p>{{ product.description }}</p>
        
        <p>
            <strong>Stock:</strong> 
            {% if product.stock > 0 %}
                <span class="badge bg-success">{{ product.stock }} en stock</span>
            {% else %}
                <span class="badge bg-danger">Rupture de stock</span>
            {% endif %}
        </p>
        
        {% if app.user and product.stock > 0 %}
            <form method="POST" action="{{ path('app_cart_add', {'id': product.id}) }}" class="mt-4">
                <div class="mb-3">
                    <label for="quantity" class="form-label">Quantité:</label>
                    <input type="number" id="quantity" name="quantity" class="form-control" value="1" min="1" max="{{ product.stock }}">
                </div>
                <button type="submit" class="btn btn-success btn-lg">Ajouter au panier</button>
            </form>
        {% elseif not app.user %}
            <p class="mt-4"><a href="{{ path('app_login') }}" class="btn btn-primary">Se connecter pour acheter</a></p>
        {% else %}
            <button class="btn btn-secondary btn-lg mt-4" disabled>Rupture de stock</button>
        {% endif %}
        
        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-lg mt-2">Retour</a>
    </div>
</div>
{% endblock %}
