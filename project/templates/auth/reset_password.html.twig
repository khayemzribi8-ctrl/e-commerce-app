{% extends "base.html.twig" %}

{% block title %}Réinitialiser le mot de passe - E-Commerce{% endblock %}

{% block content %}
<div class="auth-container" style="min-height: 70vh; display:flex; align-items:center; justify-content:center;">
    <div class="card auth-card" style="max-width:450px; width:100%; border-radius:1rem; box-shadow:0 8px 16px rgba(0,0,0,0.1);">
        <div class="auth-header" style="background:linear-gradient(135deg,#0d6efd 0%,#0b5ed7 100%); color:white; padding:2rem 1.5rem; border-radius:1rem 1rem 0 0; text-align:center;">
            <i class="bi bi-shield-lock" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
            <h2>Réinitialiser le mot de passe</h2>
        </div>
        <div class="auth-body" style="padding:2rem 1.5rem;">
            <form method="post" novalidate>
                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">
                        <i class="bi bi-lock"></i> Nouveau mot de passe
                    </label>
                    <input type="password" id="password" name="password" class="form-control form-control-lg" required minlength="8" placeholder="••••••••">
                </div>

                <div class="mb-3">
                    <label for="password_confirm" class="form-label fw-semibold">
                        <i class="bi bi-lock-fill"></i> Confirmer le mot de passe
                    </label>
                    <input type="password" id="password_confirm" name="password_confirm" class="form-control form-control-lg" required minlength="8" placeholder="••••••••">
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 mb-2">
                    <i class="bi bi-check-circle"></i> Mettre à jour le mot de passe
                </button>

                <a href="{{ path('app_login') }}" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left"></i> Retour à la connexion
                </a>
            </form>
        </div>
    </div>
</div>
{% endblock %}
