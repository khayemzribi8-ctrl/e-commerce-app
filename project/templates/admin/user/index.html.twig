{% extends "base.html.twig" %}

{% block title %}Gestion des Utilisateurs - Admin{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h2">Gestion des Utilisateurs</h1>
    <a href="{{ path('admin_user_new') }}" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Ajouter un utilisateur
    </a>
</div>

{% if users is empty %}
    <div class="alert alert-info">
        Aucun utilisateur trouvé.
    </div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Nom</th>
                    <th>Rôles</th>
                    <th>Date inscription</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td>{{ user.firstName }} {{ user.lastName }}</td>
                        <td>
                            {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                    <span class="badge bg-danger">Admin</span>
                                {% else %}
                                    <span class="badge bg-primary">Utilisateur</span>
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td>{{ user.createdAt|date('d/m/Y') }}</td>
                        <td>
                            <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-primary btn-sm">Éditer</a>
                            <form method="POST" action="{{ path('admin_user_delete', {'id': user.id}) }}" style="display:inline;" onsubmit="return confirm('Êtes-vous sûr?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
